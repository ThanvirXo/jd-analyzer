# Copy to .env for local dev (APP_STAGE unset or "dev" loads this file).
# In production, set these as real environment variables instead.

# Hosted LLM (OpenAI-compatible endpoint, e.g. vLLM/Ollama /v1)
LLM_URL=https://your-llm-host/v1
VLLM_KEY=your-llm-api-key
LLM_MODEL=your-model-name

# Server port (hosting platforms usually inject this automatically)
PORT=8220

# Shared secret the extension must send as "Authorization: Bearer <key>".
# Must match WXT_API_KEY used when building the extension. Leave empty to
# disable auth (local dev only). Generate with: openssl rand -hex 32
API_KEY=

# Set to "production" when deploying so the app does not try to load .env
# APP_STAGE=production
